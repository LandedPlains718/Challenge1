# Ollama (local, free)
#   ollama pull qwen2.5:7b
#   export LLM_PROVIDER=ollama
#   export OLLAMA_MODEL=qwen2.5:7b   # optional; this is the default
#
# Unset Gemini if you were using it before:
#   unset GEMINI_API_KEY GOOGLE_API_KEY
#
# Then:
#   python main.py 'Logistics companies in Romania'
#   # Matches are retrieved, then analyzed by the LLM into a natural-language answer.
#   python main.py 'Logistics companies in Romania' --no-answer  # retrieval only

LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b
